{
  "name": "xiahou-henan",
  "version": "0.1.0",
  "description": "A Henan sunrise and sunset glow forecasting dashboard powered by Open-Meteo forecast and air-quality data.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/youdiansmallshuai/xiahou-henan.git"
  },
  "bugs": {
    "url": "https://github.com/youdiansmallshuai/xiahou-henan/issues"
  },
  "homepage": "https://github.com/youdiansmallshuai/xiahou-henan#readme",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "esbuild server/wanxiaServer.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist-server/wanxia-server.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
